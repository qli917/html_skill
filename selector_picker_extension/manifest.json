{
  "manifest_version": 3,
  "name": "Codex HTML Main Selector Picker",
  "version": "0.1.0",
  "description": "Pick a main-content element and save its CSS selector locally.",
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
